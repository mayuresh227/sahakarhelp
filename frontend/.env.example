# Backend API Base URL
# Set this to your deployed backend URL (Railway, Vercel, or local)
NEXT_PUBLIC_API_URL=https://sahakarhelp-production.up.railway.app

# Optional: Other environment variables
# NEXT_PUBLIC_ANALYTICS_ID=

# Development settings
NODE_ENV=development

# NextAuth Configuration
# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MongoDB Connection (for NextAuth adapter)
# Use a secure MongoDB URI (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/sahakarhelp

# Optional: Rate limiting (if using Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=