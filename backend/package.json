{
  "name": "sahakarhelp-backend",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node startWorker.js",
    "test": "jest",
    "test:env": "mkdir -p $HOME/mongodb-data && ($HOME/mongodb/bin/mongod --dbpath $HOME/mongodb-data --bind_ip 127.0.0.1 --port 27017 --fork --logpath $HOME/mongodb-data/mongod.log || true); npm test",
    "postinstall": "npm run sharp:verify",
    "sharp:verify": "node -e \"try { const sharp = require('sharp'); console.log('Sharp loaded successfully'); console.log('Sharp versions:', sharp.versions); } catch(e) { console.error('Sharp failed to load:', e.message); process.exit(1); }\"",
    "sharp:rebuild": "npm rebuild sharp"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "archiver": "^7.0.1",
    "body-parser": "^1.20.2",
    "bullmq": "^5.34.2",
    "canvas": "^3.2.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^8.12.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "pdfkit": "^0.17.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "xss-clean": "^0.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.1.0",
    "mongodb-memory-server-core": "^11.1.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  },
  "_cache": "2026-04-24"
}
