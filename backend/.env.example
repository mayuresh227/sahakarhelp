# SahakarHelp Backend Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ====================
# Server Configuration
# ====================
PORT=8080
NODE_ENV=production

# ====================
# Database
# ====================
MONGO_URI=mongodb://localhost:27017/sahakarhelp
# For production, use a secure connection string with username/password:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sahakarhelp?retryWrites=true&w=majority

# ====================
# Security & Secrets
# ====================
NEXTAUTH_SECRET=your-secret-key-at-least-32-characters-long
JWT_SECRET=your-jwt-secret-key-change-in-production
SESSION_SECRET=your-session-secret

# ====================
# CORS & Frontend
# ====================
FRONTEND_URL=http://localhost:3000
# In production, set to your frontend domain (e.g., https://sahakarhelp.com)
# FRONTEND_URL=https://yourdomain.com

# ====================
# Rate Limiting (optional)
# ====================
RATE_LIMIT_WINDOW_MS=900000          # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100          # max requests per window per IP

# ====================
# File Upload Limits
# ====================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ====================
# Logging
# ====================
LOG_LEVEL=info
LOG_TO_FILE=false

# ====================
# External Services (optional)
# ====================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ====================
# Razorpay Payment Gateway
# ====================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ====================
# Advanced Security
# ====================
# Enable HTTP Strict Transport Security (HSTS) in production
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# Enable secure cookies (requires HTTPS)
SECURE_COOKIES=true

# ====================
# Monitoring & Alerts
# ====================
SENTRY_DSN=your-sentry-dsn-if-using
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# ====================
# Notes
# ====================
# 1. Generate strong secrets using: openssl rand -base64 32
# 2. Use different secrets for each environment (development, staging, production).
# 3. Regularly rotate secrets.
# 4. Never expose .env files in logs, error messages, or client‑side code.